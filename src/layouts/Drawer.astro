---
import {
  getMenuEntries,
  isMenuGroup,
  isPathActive,
  linkClass,
  withBase,
} from '@app/config/pages';

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;
const menuEntries = getMenuEntries();
---

<div
  data-mobile-menu
  class="fixed inset-x-0 top-0 z-40 border-b border-[#d8deea] bg-white/95 px-4 py-3 shadow-[0_1px_3px_rgba(31,42,68,0.08)] backdrop-blur transition-transform duration-200 lg:hidden"
>
  <div class="flex items-center justify-between gap-3">
    <button
      type="button"
      aria-label="Открыть меню"
      data-drawer-open
      class="inline-flex items-center rounded-lg border border-[#d8deea] bg-white p-2 text-[#1f2a44] transition-all hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#9eb3da]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
    </button>
    <span class="text-base font-semibold text-[#1f2a44]">2.5D Renderer</span>
  </div>
</div>

<button
  type="button"
  aria-label="Открыть меню"
  data-drawer-open
  class="fixed left-4 top-4 z-40 hidden rounded-lg border border-[#d8deea] bg-white p-2.5 text-[#1f2a44] transition-all hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-[#9eb3da] lg:inline-flex"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <line x1="4" x2="20" y1="12" y2="12"></line>
    <line x1="4" x2="20" y1="6" y2="6"></line>
    <line x1="4" x2="20" y1="18" y2="18"></line>
  </svg>
</button>

<div
  data-drawer
  class="pointer-events-none fixed inset-0 z-50 transition-all duration-300"
>
  <button
    type="button"
    aria-label="Закрыть меню"
    data-drawer-close
    class="absolute inset-0 bg-black opacity-0 transition-opacity duration-300"
  ></button>

  <aside
    data-drawer-panel
    class="absolute bottom-0 left-0 top-0 w-80 max-w-[85vw] -translate-x-full transform bg-[#eef2fb] shadow-2xl transition-transform duration-300 ease-out"
  >
    <div class="flex items-center justify-between border-b border-[#d8deea] px-4 py-4">
      <span class="text-lg font-bold text-[#1f2a44]">2.5D Renderer</span>
      <button
        type="button"
        aria-label="Закрыть меню"
        data-drawer-close
        class="rounded p-1.5 text-[#1f2a44] transition-colors hover:bg-[#d8deea]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>

    <nav class="flex flex-col gap-5 overflow-y-auto p-4" style="max-height: calc(100vh - 60px);">
      <div class="flex flex-col gap-4">
        {
          menuEntries.map((entry) =>
            isMenuGroup(entry) ? (
              <div class="flex min-w-0 flex-col gap-1">
                <button
                  type="button"
                  data-drawer-group
                  data-expanded={entry.links.some((link) =>
                    isPathActive(currentPath, link.href)
                  )
                    ? 'true'
                    : 'false'}
                  class="group flex w-full items-center justify-between rounded-md px-3 py-3 text-sm font-semibold uppercase tracking-wide text-[#6b7a8f] transition-all duration-200 hover:bg-[#d8deea] hover:text-[#1f2a44]"
                >
                  <span class="flex-1 text-left">{entry.title}</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class={`transition-all duration-200 ${
                      entry.links.some((link) => isPathActive(currentPath, link.href))
                        ? 'rotate-180'
                        : ''
                    }`}
                    aria-hidden="true"
                  >
                    <path d="m6 9 6 6 6-6"></path>
                  </svg>
                </button>

                <div
                  data-drawer-group-content
                  class={`overflow-hidden transition-all duration-200 ${
                    entry.links.some((link) => isPathActive(currentPath, link.href))
                      ? 'opacity-100'
                      : 'max-h-0 opacity-0'
                  }`}
                >
                  <ul class="m-0 list-none space-y-0.5 pl-0">
                    {entry.links.map((link) => (
                      <li>
                        <a
                          href={withBase(link.href)}
                          class={linkClass(isPathActive(currentPath, link.href))}
                        >
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ) : (
              <a
                href={withBase(entry.href)}
                class={linkClass(isPathActive(currentPath, entry.href))}
              >
                {entry.label}
              </a>
            )
          )
        }
      </div>
    </nav>
  </aside>
</div>

<script>
  const drawer = document.querySelector('[data-drawer]');
  const panel = document.querySelector('[data-drawer-panel]');
  const openButtons = document.querySelectorAll('[data-drawer-open]');
  const closeButtons = document.querySelectorAll('[data-drawer-close]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  let lastScrollY = window.scrollY;
  let isDrawerOpen = false;

  const showMobileMenu = () => {
    mobileMenu?.classList.toggle('-translate-y-full', false);
    lastScrollY = window.scrollY;
  };

  const setDrawerOpen = (isOpen: boolean) => {
    if (!drawer || !panel) return;

    isDrawerOpen = isOpen;
    drawer.classList.toggle('pointer-events-auto', isOpen);
    drawer.classList.toggle('pointer-events-none', !isOpen);
    drawer.querySelector('[data-drawer-close]')?.classList.toggle('opacity-50', isOpen);
    drawer.querySelector('[data-drawer-close]')?.classList.toggle('opacity-0', !isOpen);
    panel.classList.toggle('translate-x-0', isOpen);
    panel.classList.toggle('-translate-x-full', !isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
    showMobileMenu();
  };

  const syncGroup = (button: Element) => {
    const isExpanded = button.getAttribute('data-expanded') === 'true';
    const content = button.nextElementSibling;
    const icon = button.querySelector('svg');

    content?.classList.toggle('opacity-100', isExpanded);
    content?.classList.toggle('opacity-0', !isExpanded);
    content?.classList.toggle('max-h-0', !isExpanded);
    icon?.classList.toggle('rotate-180', isExpanded);
  };

  openButtons.forEach((button) => {
    button.addEventListener('click', () => setDrawerOpen(true));
  });
  closeButtons.forEach((button) => {
    button.addEventListener('click', () => setDrawerOpen(false));
  });

  window.addEventListener(
    'scroll',
    () => {
      if (!mobileMenu || isDrawerOpen) return;

      const currentScrollY = window.scrollY;
      const isScrollingDown = currentScrollY > lastScrollY;
      const shouldHide = isScrollingDown && currentScrollY > 64;

      mobileMenu.classList.toggle('-translate-y-full', shouldHide);
      lastScrollY = currentScrollY;
    },
    { passive: true },
  );
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setDrawerOpen(false);
    }
  });

  document.querySelectorAll('[data-drawer-group]').forEach((button) => {
    syncGroup(button);
    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('data-expanded') === 'true';
      button.setAttribute('data-expanded', isExpanded ? 'false' : 'true');
      syncGroup(button);
    });
  });
</script>
