---
import PageLayout from '@app/layouts/PageLayout.astro';
import InDevelopmentGate from '@app/pages/_components/InDevelopmentGate.astro';
import Stage from '@app/pages/stage/_islands/Stage3e';
import type { PageMetadata } from '@app/config/pages';
import { codeToHtml } from 'shiki';

export const metadata: PageMetadata = {
  title: 'Порталы 1D: соединяем сектора',
  groupTitle: 'Stage 3: Binary Space Partition',
};

const code1 = `
  function render25d(
    ctx: CanvasRenderingContext2D,
    settings: Settings,
  ) {
    const camera = settings.camera;
    const allSegments = settings.level.linedefs;
    const bspTree = buildBSPTree(allSegments);
    const solidWallRanges = createSolidWallRanges(camera);

    traverseBSPTree(bspTree, camera, (bspNode: BSPLeaf) => {
      for (const seg of bspNode.segs) {
        const sector = seg.frontSector!;

        const projection = projectSeg(camera, sector, seg);

        if (!projection) {
          continue;
        }

        if (!isPortal(seg)) {
          drawSolidWall(ctx, camera, seg, projection, solidWallRanges);
        }
      }
    });
  }

`;


const code2 = `
  interface SolidSegmentRange {
    xStart: number;
    xEnd: number;
  }

  function createSolidWallRanges(camera: Camera) {
    const ranges: SolidSegmentRange[] = [];

    ranges.push({ xStart: Number.MIN_SAFE_INTEGER, xEnd: -1 });
    ranges.push({ xStart: camera.screen.width, xEnd: Number.MAX_SAFE_INTEGER });

    return ranges;
  }

`;


const code3 = `
  function drawSolidWall(
    ctx: CanvasRenderingContext2D,
    camera:Camera, 
    // .. 
    solidWallRanges: SolidSegmentRange[]
  ) {
    // ..
    const xStart = projection.start.screenX;
    const xEnd = projection.end.screenX;
    const xFrom = Math.max(0, Math.floor(Math.min(xStart, xEnd)));
    const xTo = Math.min(camera.screen.width - 1, Math.ceil(Math.max(xStart, xEnd)));
    // ..
    for (let x = xFrom; x <= xTo; x++) {
      if (!isWallVisible(x, solidWallRanges)) {
        continue;
      }
  
      // рисуем стены
    }
  
    addSolidRange(camera, xStart, xEnd, solidWallRanges);
  }

`;


const code1Html = await codeToHtml(code1, { lang: 'ts', theme: 'github-dark' });
const code2Html = await codeToHtml(code2, { lang: 'ts', theme: 'github-dark' });
const code3Html = await codeToHtml(code3, { lang: 'ts', theme: 'github-dark' });
---

<PageLayout>
  <InDevelopmentGate />
  <section class="flex flex-col gap-4">
    <p class="py-2 text">
      Подключим к BSP-обходу порталы между секторами одинаковой высоты. Портальный сегмент больше не рисуется как непрозрачная стена и не добавляет свой диапазон X в список закрытых участков, поэтому через него остается видна дальняя геометрия.
    </p>
    <p class="py-2 text">
      Важна совместная работа двух алгоритмов: BSP задавал правильный порядок от ближнего к дальнему, а список закрытых диапазонов показывал, какие части экрана уже окончательно заполнены. Без правильного порядка дальняя стена могла бы закрыть ближнюю; без диапазонов пришлось бы обрабатывать все ветви дерева, даже когда за ближайшей стеной ничего не видно.
    </p>
    <Stage part={0} client:load />
    <p class="py-2 text">
      Обычные стены по-прежнему закрывают экран от ближних к дальним. В результате BSP задает корректный глобальный порядок, а одномерный список диапазонов быстро отбрасывает части стен, уже скрытые непрозрачной геометрией.
    </p>
    <h2 class="text-2xl">
      Wall ranges
    </h2>
    <p class="py-2 text">
      Wall range — это интервал экранных колонок от <code class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded">xStart</code> до <code class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded">xEnd</code>, который уже полностью закрыт непрозрачной стеной. Поскольку BSP отдает стены от ближних к дальним, содержимое такой колонки больше не изменится: вся следующая геометрия в ней находится за уже нарисованной стеной.
    </p>
    <p class="py-2 text">
      В начале кадра список содержит два служебных диапазона за левой и правой границами экрана. Они ограничивают рабочую область значениями от <code class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded">0</code> до ширины экрана и позволяют обрабатывать крайние стены тем же алгоритмом, без отдельных проверок для краев.
    </p>
    <p class="py-2 text">
      Перед рисованием каждой колонки <code class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded">isWallVisible</code> проверяет, не входит ли ее X-координата в закрытый диапазон. После отрисовки <code class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded">addSolidRange</code> добавляет только еще не закрытые части проекции стены. Поэтому диапазоны не перекрывают друг друга, а уже обработанные участки экрана быстро пропускаются.
    </p>
    <p class="py-2 text">
      Такой одномерный клиппинг подходит только для сплошной стены: в этом шаге она закрывает колонку целиком потолком, стеной и полом. Портал оставляет внутри колонки видимый проем, поэтому его диапазон нельзя добавлять в wall ranges. Для порталов с разной высотой потребуется отдельное вертикальное отсечение, которое появится на следующем шаге.
    </p>
    <h2 class="text-2xl">
      Немного кода
    </h2>
    <p class="py-2 text">
      Первый фрагмент показывает пропуск портальных сегментов. Следующие фрагменты описывают список закрытых диапазонов и проверку каждой экранной колонки перед рисованием стены.
    </p>
    <div set:html={code1Html} />
    <div set:html={code2Html} />
    <div set:html={code3Html} />
  </section>
</PageLayout>
