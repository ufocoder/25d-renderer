import Stage from '@app/pages/stage/_islands/Stage1d3';
import type { PageMetadata } from '@app/config/pages';

export const metadata: PageMetadata = {
  title: 'Отсечение: финальный тест',
  groupTitle: 'Stage 1: Отрисовка стен',
};
---

<PageLayout>
  <section class="flex flex-col gap-4">
    <p class="py-text">
      На этом шаге убедимся, что все наши расчёты корректны при любом угле поворота камеры.
    </p>
    <Stage part={0} client:load />
  </section>
</PageLayout>
