---
import PageLayout from '@app/layouts/PageLayout.astro';
import Stage from '@app/pages/stage/_islands/Stage2j';
import type { PageMetadata } from '@app/config/pages';

export const metadata: PageMetadata = {
  title: 'Порталы 2D: многоугольник',
  groupTitle: 'Stage 2: Отрисовка секторов',
};
---

<PageLayout>
  <section class="flex flex-col gap-4">
    <p class="py-2 text">
      Трапециевидный клиппинг несовершен, необходим многоугольник. Используем алгоритм <a href="https://en.wikipedia.org/wiki/Sutherland%E2%80%93Hodgman_algorithm" class="link underline" target="_blank">Сазерленда—Ходгмана</a> (1974?):
    </p>
    <Stage part={0} client:load />
  </section>
</PageLayout>
