---
import PageLayout from '@app/layouts/PageLayout.astro';
import Stage from '@app/pages/stage/_islands/Stage2j';
import type { PageMetadata } from '@app/config/pages';
import { PROJECT_REPO_URL } from '@app/config/repo';

export const metadata: PageMetadata = {
  title: 'Порталы 2D: многоугольник',
  groupTitle: 'Stage 2: Отрисовка секторов',
};
---

<PageLayout>
  <section class="flex flex-col gap-4">
    <p class="py-2 text">
      Обрезка в виде трапеции хорошо работает для одного портала, однако цепочка порталов может образовать область сложнее одной трапеции. Чтобы корректно сохранить пересечение всех пройденных окон, потребуется представлять область видимости произвольным многоугольником.
    </p>
    </p>
    <p class="py-2 text">
      Для пересечения выпуклых многоугольников используем алгоритм <a href="https://en.wikipedia.org/wiki/Sutherland%E2%80%93Hodgman_algorithm" class="link underline" target="_blank" rel="noopener noreferrer">Сазерленда—Ходжмана</a>. Он по очереди обрезает исходный многоугольник каждой стороной окна и передает получившиеся вершины на следующий шаг. В результате каждый сектор рисуется только через реально видимую часть всей цепочки порталов, включая наклонные границы и окна более сложной формы.
    </p>
    <Stage part={0} client:load />
    <p class="py-2">
      <a
        href={`${PROJECT_REPO_URL}/stages/Stage2j/render25d.ts`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-blue-600 transition-colors hover:text-blue-800 hover:underline"
      >
        Реализация шага на github
      </a>
    </p>
  </section>
</PageLayout>
