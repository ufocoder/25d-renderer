---
import PageLayout from '@app/layouts/PageLayout.astro';
import Stage from '@app/pages/stage/_islands/Stage3c';
import type { PageMetadata } from '@app/config/pages';
import { PROJECT_REPO_URL } from '@app/config/repo';

export const metadata: PageMetadata = {
  title: 'Тест: варианты разбития',
  groupTitle: 'Stage 3: Binary Space Partition',
};
---

<PageLayout>
  <section class="flex flex-col gap-4">
    <p class="py-2 text">
      Проверим построение BSP-дерева на нескольких типах геометрии: вложенных секторах, коридоре, пирамиде и ступенях. Слева в каждой строке показан исходный уровень, справа — его разбиение на выпуклые листья. Цвет отделяет один лист от другого, а номер показывает порядок обхода для текущего положения камеры.
    </p>
    <Stage client:load />
    <p class="py-2 text">
      Примеры показывают, что одна и та же идея работает для разных конфигураций, но структура дерева и количество подсекторов зависят от геометрии уровня и выбранных разделителей.
    </p><p class="py-2">
      <a
        href={`${PROJECT_REPO_URL}/stages/Stage3b/settings`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-blue-600 transition-colors hover:text-blue-800 hover:underline"
      >
        Настройки уровней на github
      </a>
    </p>
  </section>
</PageLayout>
