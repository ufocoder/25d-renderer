---
import PageLayout from '@app/layouts/PageLayout.astro';
import InDevelopmentGate from '@app/pages/_components/InDevelopmentGate.astro';
import Stage from '@app/pages/stage/_islands/Stage3f';
import type { PageMetadata } from '@app/config/pages';
import { codeToHtml } from 'shiki';

export const metadata: PageMetadata = {
  title: 'Порталы 2D: соединяем сектора',
  groupTitle: 'Stage 3: Binary Space Partition',
};

const code1 = `
  function render25d(
    ctx: CanvasRenderingContext2D,
    settings: Settings,
  ) {
    const camera = settings.camera;
    const allSegments = settings.level.linedefs;
    const bspTree = buildBSPTree(allSegments);
  
    const wallRanges = createSolidWallRanges(camera);
    const upperClip = new Array(camera.screen.width).fill(-1);
    const lowerClip = new Array(camera.screen.width).fill(camera.screen.height)
  
    traverseBSPTree(bspTree, camera, (bspNode: BSPLeaf) => {
      for (const seg of bspNode.segs) {
        const sector = seg.frontSector!;
  
        const projection = projectSeg(camera, sector, seg);
  
        if (!projection) {
          continue;
        }
  
        if (isPortal(seg)) {
          drawPortalSegment(ctx, camera, seg, projection, wallRanges, upperClip, lowerClip);
        } else {
          drawSolidSegment(ctx, camera, seg, projection, wallRanges, upperClip, lowerClip);
        }
      }
    });
  }
  
`;


const code1Html = await codeToHtml(code1, { lang: 'ts', theme: 'github-dark' });
---

<PageLayout>
  <InDevelopmentGate />
  <section class="flex flex-col gap-4">
    <p class="py-2 text">
      Одного диапазона по X достаточно для непрозрачных стен, но портал ограничен еще сверху и снизу. Добавим два массива размером с ширину экрана: <code class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded">upperClip</code> и <code class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded">lowerClip</code>.
    </p>
    <p class="py-2 text">
      Для каждой экранной колонки массивы хранят верхнюю и нижнюю границы еще видимой области. Непрозрачная стена заполняет доступный интервал, а портал рисует пол и потолок вокруг проема и сужает окно для следующей геометрии.
    </p>
    <Stage part={0} client:load />
    <p class="py-2 text">
      Такое поколоночное отсечение учитывает перспективный наклон границ портала и корректно работает с цепочкой секторов одинаковой высоты.
    </p>
    <h2 class="text-2xl">
      Немного кода
    </h2>
    <p class="py-2 text">
      BSP-обход остается прежним, но обычные и портальные сегменты теперь обрабатываются разными функциями и используют общие массивы вертикального клиппинга.
    </p>
    <div set:html={code1Html} />
  </section>
</PageLayout>
